{
  "name": "pi-ralph",
  "private": true,
  "version": "0.1.0",
  "description": "Standalone Pi-native iterative supervisor loop extension for reusable host-repo consumption.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Banon-Labs/pi-ralph.git"
  },
  "type": "module",
  "license": "MIT",
  "main": "src/pi-ralph-runtime.ts",
  "files": [
    "src",
    ".pi/extensions",
    "docs",
    "examples",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "AGENTS.md"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "agent",
    "supervisor",
    "loop"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": [
      "./src/pi-ralph-runtime.ts",
      "./.pi/extensions/web-content.ts",
      "./.pi/extensions/web-search.ts"
    ]
  }
}
